# Copy this file to .env and fill in your values.

# Cinema schedule source: kinominska or bycard
SCHEDULE_PARSER=bycard

# MagicINFO integration — set to false to disable
MAGICINFO_ENABLED=true
MAGICINFO_HOST=192.168.100.20
MAGICINFO_PORT=7001

# MagicINFO login credentials (used to obtain a JWT token via POST /auth)
MAGICINFO_USERNAME=admin
MAGICINFO_PASSWORD=your-password-here

# Content and schedule group names (must already exist in MagicINFO)
MAGICINFO_CONTENT_GROUP=default
MAGICINFO_SCHEDULE_GROUP=Расписание

# Schedule names for the two generated pages
MAGICINFO_SCHEDULE_NAME_1=Расписание 1
MAGICINFO_SCHEDULE_NAME_2=Расписание 2

# Device configuration
MAGICINFO_DEVICE_TYPE=LPLAYER
MAGICINFO_DEVICE_TYPE_VERSION=1.0

# Device group IDs — one per schedule page.
# Each schedule is deployed to its own device group.
# Leave empty to skip device group assignment (server default).
MAGICINFO_DEVICE_GROUP_ID_1=
MAGICINFO_DEVICE_GROUP_ID_2=

# Enable verbose request/response logging for debugging
MAGICINFO_DEBUG=false
