# Copy this file to .env and fill in your values.

# MagicINFO integration — set to false to disable
MAGICINFO_ENABLED=true
MAGICINFO_HOST=192.168.100.20
MAGICINFO_PORT=7001
MAGICINFO_API_KEY=your-api-key-here

# Content and schedule group names (must already exist in MagicINFO)
MAGICINFO_CONTENT_GROUP=default
MAGICINFO_SCHEDULE_GROUP=Расписание

# Schedule names for the two generated pages
MAGICINFO_SCHEDULE_NAME_1=Расписание 1
MAGICINFO_SCHEDULE_NAME_2=Расписание 2

# Device configuration
MAGICINFO_DEVICE_TYPE=SPLAYER
MAGICINFO_DEVICE_TYPE_VERSION=2.0
